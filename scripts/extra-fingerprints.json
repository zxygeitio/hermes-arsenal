{
  "yonyou_u8_nc": {
    "name": "用友U8/NC",
    "match": {
      "headers": [
        "(?i)Server:.*(Yonyou|u8c|uap|nccloud)",
        "(?i)X-Powered-By:.*(UAP|Yonyou)"
      ],
      "body": [
        "用友U8",
        "用友网络",
        "Yonyou",
        "NCCloud",
        "uap\\.desktop",
        "iuap"
      ],
      "cookies": [
        "(?i)(JSESSIONID|U8C|NCSESSIONID|uap_locale)="
      ]
    },
    "paths": [
      {
        "path": "/u8cloud/",
        "method": "GET",
        "desc": "U8 Cloud入口识别",
        "severity": "info",
        "check": "contains_data"
      },
      {
        "path": "/nccloud/resources/uap/rbac/login/main/index.html",
        "method": "GET",
        "desc": "NC Cloud登录页识别",
        "severity": "info",
        "check": "contains_data"
      },
      {
        "path": "/service/",
        "method": "GET",
        "desc": "用友服务目录探测",
        "severity": "low",
        "check": "contains_data"
      },
      {
        "path": "/uapws/",
        "method": "GET",
        "desc": "UAP WebService入口识别",
        "severity": "low",
        "check": "contains_data"
      }
    ]
  },
